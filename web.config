<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
   <rewrite>
  <rules>
    <rule name="Redirect to HTTPS" stopProcessing="true">
      <match url="(.*)" />
      <conditions>
        <add input="{HTTPS}" pattern="off" />
      </conditions>
      <action type="Redirect"
              url="https://4pos.in/{R:1}"
              redirectType="Permanent" />
    </rule>
  </rules>
</rewrite>
  </system.webServer>
</configuration>
